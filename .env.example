# Copy this file to .env and fill in your values.
# Load before starting:  export $(grep -v '^#' .env | xargs)
# Or let run.sh load it automatically.

# ── Institute ─────────────────────────────────────────────────────────────────
INSTITUTE_NAME="My University"

# ── Models ────────────────────────────────────────────────────────────────────
# Must be pulled in Ollama first:  ollama pull llama3.2
LLM_MODEL_NAME=llama3.2
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# keep_alive=-1 keeps model in RAM so KV-cache is reused across requests.
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_CTX=8192

# ── Admin ─────────────────────────────────────────────────────────────────────
# Required. No default — server will not start without this.
ADMIN_PASSWORD=changeme

# ── CORS ──────────────────────────────────────────────────────────────────────
# Required. Comma-separated list of allowed browser origins.
# Use * for development only. In production, set to your institute domain.
# Example: CORS_ORIGINS=https://institute.edu
CORS_ORIGINS=*

# ── Semantic Scholar ──────────────────────────────────────────────────────────
# Optional. Without a key: 100 req/5 min.  With a key: 10 req/s.
# Get a free key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_QUERIES=10/minute

# ── Retrieval tuning ──────────────────────────────────────────────────────────
RETRIEVAL_K=5
RETRIEVAL_FETCH_K=20
MIN_SIMILARITY_DISTANCE=0.85
CACHE_HIT_DISTANCE=0.08

# ── Scoring ───────────────────────────────────────────────────────────────────
# Recency bonus added to RRF scores.  0 = disabled, 0.01 = subtle boost.
RECENCY_WEIGHT=0.01

# Copy this file to .env and fill in your values.
# Load before starting:  export $(grep -v '^#' .env | xargs)
# Or let run.sh load it automatically.

# ── Institute ─────────────────────────────────────────────────────────────────
INSTITUTE_NAME="My University"

# ── Models ────────────────────────────────────────────────────────────────────
# Must be pulled in Ollama first:  ollama pull llama3.2
LLM_MODEL_NAME=llama3.2
# Ollama model tag (ollama pull all-minilm) — NOT a HuggingFace repo path
EMBEDDING_MODEL_NAME=all-minilm
# sentence-transformers path. Empty = run without reranking (reported in /health)
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# keep_alive=-1 keeps model in RAM so KV-cache is reused across requests.
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_CTX=8192

# ── Admin ─────────────────────────────────────────────────────────────────────
# Required. No default — server will not start without this.
ADMIN_PASSWORD=changeme

# ── CORS ──────────────────────────────────────────────────────────────────────
# Required. Comma-separated list of allowed browser origins.
# Use * for development only. In production, set to your institute domain.
# Example: CORS_ORIGINS=https://institute.edu
CORS_ORIGINS=*

# ── Semantic Scholar ──────────────────────────────────────────────────────────
# Optional. Without a key: 100 req/5 min.  With a key: 10 req/s.
# Get a free key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_QUERIES=10/minute

# ── Retrieval tuning ──────────────────────────────────────────────────────────
RETRIEVAL_K=5
RETRIEVAL_FETCH_K=20
MIN_SIMILARITY_DISTANCE=0.85
CACHE_HIT_DISTANCE=0.08

# ── Scoring ───────────────────────────────────────────────────────────────────
# Recency bonus added to RRF scores.  0 = disabled, 0.01 = subtle boost.
RECENCY_WEIGHT=0.01

# ── Ingestion bounds ──────────────────────────────────────────────────────────
# Papers fetched per registered person, newest first.  Bounds index size,
# embedding time and peak sync memory.  0 = unlimited (needs an API key).
MAX_PAPERS_PER_PERSON=200
# Documents per embedding request.  The vector store would otherwise send an
# entire sync in one call, which the embedding server rejects once large enough.
EMBED_BATCH_SIZE=64

# ── Reranking ─────────────────────────────────────────────────────────────────
# true = refuse to start if the reranker cannot load, instead of silently
# falling back to fusion order (a material ranking regression).
RERANKER_REQUIRED=false
# How much the cross-encoder may override fusion order.
#   1.0 = pure cross-encoder    0.0 = fusion order only
# See docs/retrieval-experiments.md §5.10 for the sweep behind this default.
RERANK_BLEND=0.5
# Minimum cross-encoder score to reach the LLM.  Empty = no floor.
MIN_RERANK_SCORE=

# ── Retrieval ablation axes ───────────────────────────────────────────────────
# Changing these changes production behaviour.  They exist so eval/ablate.py can
# measure each stage's contribution; every value is recorded in the query trace.
RETRIEVAL_MODE=hybrid
ENABLE_QUERY_EXPANSION=true
# BM25 candidates must score strictly above this.  Keep > 0: a query sharing no
# token with the corpus scores 0 against every document and would otherwise
# hand RRF a full page of noise.
BM25_MIN_SCORE=0.0
RRF_K=60
RRF_WEIGHT_DENSE=1.0
RRF_WEIGHT_SPARSE=1.0
# Re-apply the similarity guard to BM25-only candidates, which never faced it.
ENFORCE_GUARD_POST_FUSION=true

# ── Index (applied only when the Chroma collection is first created) ──────────
HNSW_M=48
HNSW_CONSTRUCTION_EF=200
HNSW_SEARCH_EF=150

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_MAX_AGE_DAYS=15

# ── Rate limiting (remaining) ─────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_ADMIN=60/minute

# ── Evaluation ────────────────────────────────────────────────────────────────
# Scores every query with RAGAS in the request path.  Adds seconds of
# user-visible latency; intended for diagnosis, not steady state.
ENABLE_RAGAS_SCORING=false
